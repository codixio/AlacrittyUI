<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AlacrittyUI.ViewModels"
             xmlns:models="clr-namespace:AlacrittyUI.Models"
             xmlns:res="clr-namespace:AlacrittyUI.Resources"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="AlacrittyUI.Views.ColorEditorView"
             x:DataType="vm:ColorEditorViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="ColorSwatchTemplate" x:DataType="models:ColorEntry">
            <Border Padding="10" Margin="5" CornerRadius="8"
                    Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}">
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <Border Width="48" Height="48" CornerRadius="8"
                            Background="{Binding Preview}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1" />
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding HexValue}" Width="120" FontSize="14"
                                     FontFamily="Consolas,Menlo,monospace"
                                     Padding="6,4" MinHeight="0" />
                            <TextBlock Text="!" Foreground="#dc3545" FontWeight="Bold" FontSize="16"
                                       IsVisible="{Binding HasError}" VerticalAlignment="Center"
                                       ToolTip.Tip="Invalid hex color (#RRGGBB)" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <TabControl TabStripPlacement="Top" Padding="12" FontSize="15">
        <!-- Palette tab -->
        <TabItem Header="{x:Static res:Strings.SubTabPalette}">
                <StackPanel Spacing="16" Margin="12">
                    <!-- Primary -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Static res:Strings.SectionPrimary}"
                                   FontSize="20" FontWeight="Bold" Margin="6,0" />
                        <ItemsControl ItemsSource="{Binding PrimaryColors}"
                                      ItemTemplate="{StaticResource ColorSwatchTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Normal -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Static res:Strings.SectionNormal}"
                                   FontSize="20" FontWeight="Bold" Margin="6,0" />
                        <ItemsControl ItemsSource="{Binding NormalColors}"
                                      ItemTemplate="{StaticResource ColorSwatchTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Bright -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Static res:Strings.SectionBright}"
                                   FontSize="20" FontWeight="Bold" Margin="6,0" />
                        <ItemsControl ItemsSource="{Binding BrightColors}"
                                      ItemTemplate="{StaticResource ColorSwatchTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
        </TabItem>

        <!-- Special tab: Cursor, Selection, Search, Footer -->
        <TabItem Header="{x:Static res:Strings.SubTabSpecial}">
            <StackPanel Spacing="14" Margin="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionCursor}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding CursorColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionSelection}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding SelectionColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionSearch}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding SearchColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionFooter}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding FooterColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Spacing="6" Margin="6,4,0,0">
                    <CheckBox Content="{x:Static res:Strings.ToggleBoldBright}" IsChecked="{Binding DrawBoldTextWithBrightColors}" />
                    <CheckBox Content="{x:Static res:Strings.ToggleTransparentBg}" IsChecked="{Binding TransparentBackgroundColors}" />
                </StackPanel>
            </StackPanel>
        </TabItem>

        <!-- Extended tab: Vi-Mode, Hints, Line Indicator, Dim -->
        <TabItem Header="{x:Static res:Strings.SubTabExtended}">
            <StackPanel Spacing="14" Margin="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionViModeCursor}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding ViModeCursorColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionHintsColors}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding HintsColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionLineIndicator}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding LineIndicatorColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Static res:Strings.SectionDim}" FontSize="18" FontWeight="Bold" Margin="6,0" />
                    <ItemsControl ItemsSource="{Binding DimColors}" ItemTemplate="{StaticResource ColorSwatchTemplate}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>
