<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AlacrittyUI.ViewModels"
             xmlns:res="clr-namespace:AlacrittyUI.Resources"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="AlacrittyUI.Views.InfoView"
             x:DataType="vm:InfoViewModel">

    <ScrollViewer>
        <StackPanel Spacing="24" Margin="32" MaxWidth="500">
            <!-- App name + version -->
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="{Binding AppName}"
                           FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                           FontSize="14" Opacity="0.6"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Description -->
            <TextBlock Text="{x:Static res:Strings.InfoDescription}"
                       FontSize="14" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Opacity="0.8" />

            <Separator />

            <!-- Developer info -->
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <!-- Developer -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{x:Static res:Strings.InfoDeveloper}"
                               FontWeight="SemiBold" Margin="0,4" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding Developer}" Margin="0,4" />

                    <!-- Website -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{x:Static res:Strings.LabelWebsite}" FontWeight="SemiBold" Margin="0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,4"
                               Cursor="Hand">
                        <Underline>
                            <Run Text="{Binding Website}" />
                        </Underline>
                    </TextBlock>

                    <!-- Repo -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{x:Static res:Strings.LabelRepository}" FontWeight="SemiBold" Margin="0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4"
                               Cursor="Hand">
                        <Underline>
                            <Run Text="{Binding RepoUrl}" />
                        </Underline>
                    </TextBlock>

                    <!-- Alacritty -->
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="Alacritty" FontWeight="SemiBold" Margin="0,4" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,4"
                               Cursor="Hand">
                        <Underline>
                            <Run Text="{Binding AlacrittyRepoUrl}" />
                        </Underline>
                    </TextBlock>

                    <!-- Alacritty version -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="{x:Static res:Strings.InfoAlacrittyVersion}"
                               FontWeight="SemiBold" Margin="0,4" />
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="{Binding AlacrittyVersion}" Margin="0,4" />
                </Grid>
            </StackPanel>

            <Separator />

            <!-- Copyright -->
            <TextBlock HorizontalAlignment="Center" Opacity="0.5" FontSize="12">
                <Run Text="&#169; " /><Run Text="{Binding Year}" /><Run Text=" " /><Run Text="{Binding Developer}" />
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
